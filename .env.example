# Copy to .env and fill in. Values below match docker-compose defaults for local dev.

# Consumed directly by docker-compose.yml (Postgres/RabbitMQ container
# creds + gateway DB init script). App services read the *_URL vars
# below instead — keep both sets in sync.
POSTGRES_USER=content_user
POSTGRES_PASSWORD=content_pass
POSTGRES_DB=content_db
GATEWAY_DB_USER=gateway_user
GATEWAY_DB_PASSWORD=gateway_pass
GATEWAY_DB_NAME=gateway_db
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=analytics_pass
ANALYTICS_DB_NAME=analytics_db
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

DATABASE_URL=postgresql://content_user:content_pass@localhost:5432/content_db
RABBITMQ_URL=amqp://admin:admin@localhost:5672
GATEWAY_DATABASE_URL=postgresql://gateway_user:gateway_pass@localhost:5432/gateway_db
ANALYTICS_DATABASE_URL=postgresql://analytics_user:analytics_pass@localhost:5432/analytics_db
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me
INTERNAL_JWT_SECRET=change-me
CONTENT_SERVICE_URL=http://localhost:3001
# Kafka broker address — shared across every service that touches Kafka
# (content-service's outbox relay, analytics-service's consumer). Each
# service's own Kafka client id is a compile-time constant, not env-configured
# (see KafkaMessagingModule.forRoot() in that service's module).
KAFKA_BROKERS=localhost:9092
# Cloudflare Workers AI — fill in with your own account (dashboard > Workers AI > API tokens).
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ADR-0013: set to "json" for one-line structured logs (aggregation-ready);
# any other value (or unset) keeps human-readable console logs for local dev.
LOG_FORMAT=
