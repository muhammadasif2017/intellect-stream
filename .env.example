# Copy to .env and fill in. Values below match docker-compose defaults for local dev.

# Consumed directly by docker-compose.yml (Postgres/RabbitMQ container
# creds + gateway DB init script). App services read the *_URL vars
# below instead — keep both sets in sync.
POSTGRES_USER=content_user
POSTGRES_PASSWORD=content_pass
POSTGRES_DB=content_db
GATEWAY_DB_USER=gateway_user
GATEWAY_DB_PASSWORD=gateway_pass
GATEWAY_DB_NAME=gateway_db
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

DATABASE_URL=postgresql://content_user:content_pass@localhost:5432/content_db
RABBITMQ_URL=amqp://admin:admin@localhost:5672
GATEWAY_DATABASE_URL=postgresql://gateway_user:gateway_pass@localhost:5432/gateway_db
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me
INTERNAL_JWT_SECRET=change-me
CONTENT_SERVICE_URL=http://localhost:3001
