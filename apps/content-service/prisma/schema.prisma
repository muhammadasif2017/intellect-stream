// Content Service owns this schema — DB-per-service boundary (SPEC, Decision 5).
// Connection URL lives in prisma.config.ts (Prisma 7 convention).
// Models are added at milestone 3 step 3 (Post) and step 5 (Outbox).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ModerationStatus {
  pending
  approved
  rejected
}

model Post {
  id          String           @id @default(cuid())
  authorId    String
  content     String
  status      ModerationStatus @default(pending)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// BUG-0006: attempts/lastAttemptAt let the relay quarantine rows that can
// never publish (unroutable eventType, poison payload) instead of letting
// them occupy batch slots forever. Quarantined rows stay in-table for manual
// replay (reset attempts) — decision 14's never-silent-drop guarantee holds.
model OutboxMessage {
  id           String    @id @default(uuid())
  correlationId String
  eventType    String
  eventVersion Int       @default(1)
  source       String
  occurredAt   DateTime  @default(now())
  payload      Json
  publishedAt  DateTime?
  attempts     Int       @default(0)
  lastAttemptAt DateTime?

  @@index([publishedAt, occurredAt])
}

// Decision 6: DB consumers dedupe via a unique constraint on the message id.
// Written in the same transaction as the post update it guards — a retried
// delivery hits this row's unique constraint and is dropped, not reapplied.
model ProcessedMessage {
  messageId   String   @id
  processedAt DateTime @default(now())
}